{
  "theme": {
    "name": "videoforge-default",
    "primaryColor": "#4A90D9",
    "background": {
      "base": "#0F172A",
      "elevated": "#162033",
      "surface": "#1E293B",
      "gradient": "linear-gradient(135deg, #0F172A 0%, #162033 55%, #1E293B 100%)",
      "panelGradient": "linear-gradient(135deg, #0F172A 0%, #162033 100%)"
    },
    "text": {
      "primary": "#E5EEF8",
      "muted": "#94A3B8",
      "subtle": "rgba(229, 238, 248, 0.65)"
    },
    "accent": {
      "secondary": "#F59E0B",
      "info": "#38BDF8",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "error": "#F87171",
      "highlight": "#FACC15"
    },
    "diff": {
      "added": "rgba(34, 197, 94, 0.16)",
      "addedBorder": "rgba(34, 197, 94, 0.42)",
      "removed": "rgba(248, 113, 113, 0.16)",
      "removedBorder": "rgba(248, 113, 113, 0.42)"
    },
    "chrome": {
      "border": "rgba(148, 163, 184, 0.18)",
      "panel": "rgba(255, 255, 255, 0.04)",
      "dotRed": "#FF5F57",
      "dotYellow": "#FEBC2E",
      "dotGreen": "#28C840"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "stack": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    },
    "body": {
      "family": "Inter",
      "stack": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    },
    "mono": {
      "family": "JetBrains Mono",
      "stack": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace"
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "section": 64
  },
  "motion": {
    "entrance": {
      "damping": 14,
      "stiffness": 90
    }
  },
  "code": {
    "theme": {
      "name": "poimandres",
      "background": "#111827",
      "text": "#E5EEF8",
      "keyword": "#7DD3FC",
      "string": "#F9A8D4",
      "number": "#86EFAC",
      "comment": "#94A3B8",
      "function": "#FCD34D",
      "variable": "#C4B5FD",
      "type": "#5EEAD4",
      "operator": "#E5EEF8",
      "lineNumber": "#64748B",
      "highlightBg": "rgba(250, 204, 21, 0.12)",
      "activeBorder": "#FACC15"
    }
  },
  "animotion": {
    "theme": {
      "deckBackground": "#0F172A",
      "panelBackground": "#1E293B",
      "textColor": "#E5EEF8",
      "accentColor": "#4A90D9",
      "codeTheme": "poimandres",
      "headingFont": "Inter",
      "bodyFont": "Inter",
      "monoFont": "JetBrains Mono"
    }
  },
  "manim": {
    "backgroundColor": "#0F172A",
    "textColor": "#E5EEF8",
    "mutedTextColor": "#94A3B8",
    "primaryColor": "#4A90D9",
    "secondaryColor": "#F59E0B",
    "successColor": "#22C55E",
    "errorColor": "#F87171",
    "codeBackground": "#111827",
    "codeTextColor": "#E5EEF8",
    "headingFont": "Inter",
    "bodyFont": "Inter",
    "monoFont": "JetBrains Mono"
  },
  "hud": {
    "scanline": "rgba(255, 255, 255, 0.03)",
    "grid": "rgba(148, 163, 184, 0.06)",
    "reticle": "#4A90D9",
    "reticleOpacity": 0.7,
    "cornerBracket": "rgba(148, 163, 184, 0.35)",
    "dataReadout": {
      "background": "rgba(15, 23, 42, 0.85)",
      "border": "rgba(74, 144, 217, 0.5)",
      "label": "#94A3B8",
      "value": "#E5EEF8",
      "accent": "#4A90D9"
    }
  },
  "glass": {
    "backdropBlur": 12,
    "background": "rgba(30, 41, 59, 0.6)",
    "border": "rgba(255, 255, 255, 0.08)",
    "highlight": "rgba(255, 255, 255, 0.03)",
    "shadow": "0 8px 32px rgba(0, 0, 0, 0.4)",
    "borderRadius": 16
  },
  "device": {
    "phone": {
      "bezel": "#1C1C1E",
      "bezelRadius": 40,
      "frame": "#2C2C2E",
      "shadow": "0 16px 48px rgba(0, 0, 0, 0.5)",
      "screenRadius": 32
    },
    "tablet": {
      "bezel": "#1C1C1E",
      "bezelRadius": 24,
      "frame": "#2C2C2E",
      "shadow": "0 20px 60px rgba(0, 0, 0, 0.5)",
      "screenRadius": 18
    },
    "laptop": {
      "bezel": "#1A1A1A",
      "base": "#2C2C2E",
      "shadow": "0 24px 64px rgba(0, 0, 0, 0.5)",
      "keyboardGradient": "linear-gradient(180deg, #3A3A3C 0%, #2C2C2E 100%)",
      "screenRadius": 8
    },
    "monitor": {
      "bezel": "#222222",
      "stand": "#3A3A3C",
      "shadow": "0 24px 64px rgba(0, 0, 0, 0.45)",
      "screenRadius": 4
    }
  },
  "chart": {
    "gridLine": "rgba(255, 255, 255, 0.08)",
    "axisLine": "rgba(255, 255, 255, 0.3)",
    "axisLabel": "#94A3B8",
    "series": ["#4A90D9", "#F59E0B", "#22C55E", "#F87171", "#38BDF8", "#C4B5FD"],
    "areaFill": "rgba(74, 144, 217, 0.12)",
    "barRadius": 4,
    "dotRadius": 6,
    "lineWidth": 3
  },
  "showcase": {
    "overlayGradient": "linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.85) 100%)",
    "heroOverlay": "linear-gradient(135deg, rgba(74, 144, 217, 0.15) 0%, rgba(245, 158, 11, 0.1) 100%)",
    "cta": {
      "background": "linear-gradient(135deg, #4A90D9, #F59E0B)",
      "text": "#FFFFFF",
      "borderRadius": 12,
      "shadow": "0 4px 16px rgba(74, 144, 217, 0.25)"
    },
    "accentGlow": "rgba(74, 144, 217, 0.25)",
    "particle": "#38BDF8",
    "sparkle": "#FACC15"
  }
}
